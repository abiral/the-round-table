# Root .env for docker-compose.
#
# Copy to .env (cp .env.example .env) and adjust ports if any clash with
# services already running on your machine. Inside the docker network the
# containers still talk to each other on standard ports (5432, 6379, 8000,
# 5173); only the host-side ports below are affected by these values.

# ── Service ports (host side) ────────────────────────────────────────────
# Defaults avoid the standard 5432 / 6379 so a local Postgres / Redis can
# keep running alongside.
POSTGRES_PORT=5433
REDIS_PORT=6380
BACKEND_PORT=8000
FRONTEND_PORT=5173

# ── Postgres credentials (only used by the docker postgres service) ──────
POSTGRES_USER=brainstorm
POSTGRES_PASSWORD=brainstorm
POSTGRES_DB=brainstorm

# ── LLM keys ─────────────────────────────────────────────────────────────
# Leaving these blank is fine: the backend container reads backend/.env via
# env_file, so your existing keys there will be used. Setting them here
# overrides backend/.env for the docker run only.
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
