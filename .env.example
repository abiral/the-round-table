ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...                    # optional, enables Gemini for some experts
CORS_ORIGINS=http://localhost:5173

# Database. Matches docker-compose defaults (postgres on host port 5433).
# Switch port to 5432 if you want to point at a local Postgres instead.
DATABASE_URL=postgresql+asyncpg://brainstorm:brainstorm@localhost:5433/brainstorm

# Auth, JWE (encrypted JWT) in httpOnly cookie.
# Generate once with:
#   python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
JWE_KEY=
JWE_TTL_MINUTES=10080                     # 7 days
COOKIE_SECURE=false                       # set true in production (HTTPS)
